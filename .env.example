# Telegram Bot Token (lấy từ @BotFather)
TOKEN=your_telegram_bot_token

# Tên username bot (không có @)
BOT_USERNAME=xuongintyphu_bot

# Supabase credentials
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key

# URL của webapp (deploy trên Vercel/Netlify/...)
WEBAPP_URL=https://your-webapp-url.vercel.app

# Telegram ID của admin (để nhận thông báo yêu cầu rút tiền)
ADMIN_CHAT_ID=your_telegram_id

# Port server (Railway/Render tự set)
PORT=3000
